{
  extends: [
    "config:best-practices"
  ],
  dependencyDashboard: false,
  // Scan the central source file for Renovate only in the terraforms repository
  // (additive, so the default patterns are still kept; this path does not
  // exist in the distribution target repositories).
  "github-actions": {
    managerFilePatterns: [
      "/(^|/)environments/shared/cruise/workflow(-private)?\\.yml$/"
    ],
  },
  woodpecker: {
    managerFilePatterns: [
      "/(^|/)environments/shared/cruise/woodpecker-cruise\\.yaml$/"
    ],
  },
  minimumReleaseAge: "3 days",
  lockFileMaintenance: {
    minimumReleaseAge: null,
  },
  vulnerabilityAlerts: {
    minimumReleaseAge: null,
  },
  packageRules: [
    {
      matchUpdateTypes: [
        "minor",
        "patch",
        "digest",
        "pinDigest"
      ],
      groupName: "all minor, patch, and digest updates",
      groupSlug: "all-minor-patch-digest-updates",
    },
    {
      matchManagers: [
        "github-actions"
      ],
      minimumReleaseAge: "7 days"
    },
    {
      // Do not let files distributed by Terraform be updated on the repository side
      // (to avoid fighting over the source of truth). ignorePaths is non-mergeable
      // and would override the preset's exclusions, so disable via packageRules instead.
      matchFileNames: [
        ".github/workflows/cruise.yml",
        ".woodpecker/cruise.yaml",
        ".woodpecker/cruise-run.sh",
        "cruise.yaml",
      ],
      enabled: false,
    }
  ]
}
